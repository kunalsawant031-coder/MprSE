// ─────────────────────────────────────────────────────────────────────────────
//  OUTPUT FORMAT
//  Order: HTML → JS → CSS
//  Reason: JS (routing logic) is more critical than CSS. If truncation happens,
//  we'd rather lose some CSS than lose the navigation JS entirely.
// ─────────────────────────────────────────────────────────────────────────────
const OUTPUT_FORMAT = `
OUTPUT FORMAT — READ CAREFULLY AND FOLLOW EXACTLY
Your response must start with ===HTML=== and contain nothing before it.

===HTML===
(complete index.html here)
===JS===
(complete script.js here)
===CSS===
(complete style.css here)
===END===

MANDATORY OUTPUT RULES:
1. Start IMMEDIATELY with ===HTML=== — zero text before it.
2. Do NOT use markdown code fences anywhere (no \`\`\`html or \`\`\`).
3. NEVER put <link rel="stylesheet"> in the HTML — CSS is injected separately.
4. NEVER put <script src="script.js"> in the HTML — JS is injected separately.
5. External CDN links (Google Fonts <link>, icon libraries) ARE allowed in HTML.
6. Write COMPLETE, UNTRUNCATED code for all 3 sections.
`.trim();

function buildInitialPrompt(category, mainPrompt) {
    const structure = CATEGORY_STRUCTURES[category?.toLowerCase()] || CATEGORY_STRUCTURES.general;

    return `You are a world-class senior frontend engineer and UI/UX designer. Your task is to generate a visually stunning, fully functional ${category} website — the kind that wins design awards.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 USER REQUEST
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Category: ${category}
Description: "${mainPrompt}"

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 REQUIRED PAGE SECTIONS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
${structure}
Always include: Home, About, Contact.

