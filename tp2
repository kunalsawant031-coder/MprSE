• Images: https://picsum.photos/800/600?random=1 through ?random=20 (vary the numbers)
• All content must be REAL and specific to the request — no "Lorem ipsum", no placeholder names
• Every section must have a compelling heading, subheading, and real body content
• At least one animated element per section (fade-in, slide-in, counter, etc.)

${OUTPUT_FORMAT}`;
}

function buildRefinementPrompt(currentCode, refinementPrompts, freeformPrompt) {
    const parts = [];
    if (refinementPrompts?.content) parts.push(`CONTENT CHANGES: ${refinementPrompts.content}`);
    if (refinementPrompts?.color) parts.push(`DESIGN/COLOR CHANGES: ${refinementPrompts.color}`);
    if (refinementPrompts?.functionality) parts.push(`FUNCTIONALITY CHANGES: ${refinementPrompts.functionality}`);
    if (freeformPrompt?.trim()) parts.push(`GENERAL CHANGES: ${freeformPrompt}`);

    const html = (currentCode?.html || '').substring(0, 12000);
    const js = (currentCode?.js || '').substring(0, 5000);
    const css = (currentCode?.css || '').substring(0, 8000);

    return `You are an expert frontend developer. Refine the existing website code below precisely.

REQUESTED CHANGES:
${parts.length ? parts.join('\n') : 'Improve overall quality, polish, and visual design.'}

EXISTING CODE:
===HTML===
${html}
===JS===
${js}
===CSS===
${css}
===END===

INSTRUCTIONS:
1. Apply ALL requested changes precisely and completely.
2. Preserve everything that was NOT asked to change.
3. Return COMPLETE code for all 3 files — never truncate.
4. Keep the same hash-based routing architecture.

${OUTPUT_FORMAT}`;
}

// ─────────────────────────────────────────────────────────────────────────────
//  PARSER — 3-layer fallback
//  Order matches the output format: HTML → JS → CSS
// ─────────────────────────────────────────────────────────────────────────────
function parseDelimitedResponse(rawText) {
    if (!rawText) throw new Error('Empty AI response.');

    // Strip markdown fences
    const text = rawText
        .replace(/\r\n/g, '\n')
        .replace(/^```[a-z]*\n?/im, '')
        .replace(/```\s*$/im, '')
        .trim();

    // Layer 1: delimiter-based extraction
    // $ in lookahead is critical — handles truncated responses with no end marker
    const htmlMatch = text.match(/===HTML===\s*([\s\S]*?)(?====JS===|===CSS===|===END===|$)/i);
    const jsMatch = text.match(/===JS===\s*([\s\S]*?)(?====CSS===|===END===|$)/i);
    const cssMatch = text.match(/===CSS===\s*([\s\S]*?)(?====END===|$)/i);

    let html = (htmlMatch?.[1] || '').trim();
    let js = (jsMatch?.[1] || '').trim();
    let css = (cssMatch?.[1] || '').trim();

    console.log(`[Parser L1] html:${html.length} js:${js.length} css:${css.length}`);

    if (!html) {
        console.error('[Parser] No HTML found. First 500 chars:\n', text.substring(0, 500));
        throw new Error('AI did not follow the output format — no HTML content found.');
    }

    // Layer 2: extract JS from inline <script> tags if missing
    if (!js) {
        const scriptRx = /<script(?![^>]*\bsrc\b)[^>]*>([\s\S]*?)<\/script>/gi;
        const hits = [...html.matchAll(scriptRx)];
        if (hits.length > 0) {
            js = hits.map(m => m[1].trim()).filter(Boolean).join('\n\n');
            html = html.replace(scriptRx, '');
            console.log(`[Parser L2] Extracted JS from <script> tags: ${js.length} chars`);
        }
    }

    // Layer 3: extract CSS from inline <style> tags if missing
    if (!css) {
        const styleRx = /<style[^>]*>([\s\S]*?)<\/style>/gi;
        const hits = [...html.matchAll(styleRx)];
        if (hits.length > 0) {
            css = hits.map(m => m[1].trim()).filter(Boolean).join('\n\n');
            html = html.replace(styleRx, '');
            console.log(`[Parser L3] Extracted CSS from <style> tags: ${css.length} chars`);
        }
    }

    // Post-process: remove local file references that 404 in the iframe
    html = html
        .replace(/<link[^>]+href=["'][^"']*\.css["'][^>]*\/?>/gi, '')
        .replace(/<script[^>]+src=["'][^"']*script\.js["'][^>]*>\s*<\/script>/gi, '');

    console.log(`[Parser Final] html:${html.length} js:${js.length} css:${css.length}`);
    return { html, css, js };
}

// ─────────────────────────────────────────────────────────────────────────────
//  MAIN ROUTE HANDLER
// ─────────────────────────────────────────────────────────────────────────────
export async function POST(request) {
    try {
        const body = await request.json().catch(() => ({}));
        const {
            category = 'general',
            prompt: mainPrompt = '',
            mode = 'initial',
            currentCode = null,
            refinementPrompts = {},
            freeformPrompt = '',
        } = body;

        if (mode === 'initial' && !mainPrompt?.trim()) {
            return NextResponse.json({ error: 'A prompt is required.' }, { status: 400 });
        }

        const cookieStore = await cookies();
        let credits = parseInt(cookieStore.get('user-credits')?.value || '50', 10);
        const cost = CREDIT_COSTS[mode] || 0;

        if (credits < cost) {
            return NextResponse.json({ error: `Insufficient credits. Need ${cost}, have ${credits}.` }, { status: 403 });
        }

        const apiKey = process.env.GEMINI_API_KEY || process.env.GEMINI_API_KEY2;
        if (!apiKey) {
            return NextResponse.json({ error: 'Gemini API key not configured. Add GEMINI_API_KEY to .env.local' }, { status: 500 });
        }

        const prompt = mode === 'initial'
            ? buildInitialPrompt(category, mainPrompt)
            : buildRefinementPrompt(currentCode, refinementPrompts, freeformPrompt);

        const genAI = new GoogleGenerativeAI(apiKey);
        const model = genAI.getGenerativeModel({
            model: GEMINI_MODEL,
            generationConfig: {
                temperature: mode === 'initial' ? 0.8 : 0.4,
                maxOutputTokens: 8192,
            },
        });

        let resultData = null;
        let lastError = null;

        for (let attempt = 0; attempt <= MAX_RETRIES; attempt++) {
            if (attempt > 0) {
                console.log(`[Gemini] retry ${attempt}…`);
                await new Promise(r => setTimeout(r, 1500));
            }
            try {
                const result = await model.generateContent(prompt);
                const rawText = result.response.text();
                console.log(`[Gemini] attempt ${attempt + 1} — raw length: ${rawText.length}`);
                resultData = parseDelimitedResponse(rawText);
                if (resultData.html) break;
            } catch (err) {
                lastError = err;
                console.warn(`[Gemini] attempt ${attempt + 1} failed:`, err.message);
            }
        }

        if (!resultData?.html) {
            return NextResponse.json({
                error: 'Generation failed. Please try again.',
                details: lastError?.message || 'Unknown error',
            }, { status: 500 });
        }

        credits -= cost;
        cookieStore.set('user-credits', String(credits), { path: '/', maxAge: 60 * 60 * 24 * 30, httpOnly: false });

        return NextResponse.json({
            html: resultData.html,
            css: resultData.css,
            js: resultData.js,
            creditsRemaining: credits,
            cost,
            mode,
        });

    } catch (error) {
        console.error('[Generate] Unhandled error:', error);
        return NextResponse.json({ error: 'Internal server error', details: error?.message }, { status: 500 });
    }
}